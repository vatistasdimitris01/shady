#!/bin/sh
SCRIPT="$0"
while [ -L "$SCRIPT" ]; do
  DIR="$(cd "$(dirname "$SCRIPT")" && pwd)"
  LINK="$(readlink "$SCRIPT")"
  [[ "$LINK" != /* ]] && SCRIPT="$DIR/$LINK" || SCRIPT="$LINK"
done
PACKAGE_DIR="$(cd "$(dirname "$SCRIPT")/.." && pwd)"
exec npx --prefix "$PACKAGE_DIR" tsx "$PACKAGE_DIR/src/cli.tsx" "$@"
